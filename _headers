# Dockerfile
/**/Dockerfile
  content-type: text/plain; charset=utf-8
  configuration-cache-control: max-age=0
/**/Dockerfile.*
  content-type: text/plain; charset=utf-8
  configuration-cache-control: max-age=0

# sh
/**/*.sh
  content-type: text/plain; charset=utf-8
  configuration-cache-control: max-age=0
/**/*.bash
  content-type: text/plain; charset=utf-8
  configuration-cache-control: max-age=0